<div class="card shadow-sm border-0">
  {{!-- admin avatar --}}
  {{> user-avatar-card avatarBg="dc3545" badgeClass="bg-danger" badgeLabel="Administrator"}}
  
  <div class="list-group list-group-flush profile-nav small">
    
    {{!-- 1. Account Settings --}}
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 {{#if (eq activeSection 'profile')}}active fw-bold{{/if}}" 
       href="/admin/account/profile">
      <i class="bi bi-person-gear fs-5"></i> 
      <span>Account Settings</span>
    </a>
    
    {{!-- 2. Quản lý danh mục (4.1) --}}
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 {{#if (eq activeSection 'categories')}}active fw-bold{{/if}}" 
       href="/admin/categories/list">
      <i class="bi bi-tags fs-5"></i> 
      <span>Manage Categories</span>
    </a>

    {{!-- 3. Quản lý sản phẩm (4.2) --}}
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 {{#if (eq activeSection 'products')}}active fw-bold{{/if}}" 
       href="/admin/products/list">
       <i class="bi bi-box-seam fs-5"></i> 
       <span>Manage Products</span>
    </a>

    {{!-- 4. Quản lý người dùng (4.3) --}}
    {{!-- Bao gồm: Xem danh sách, Xoá, Sửa, và DUYỆT NÂNG CẤP --}}
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 {{#if (eq activeSection 'users')}}active fw-bold{{/if}}" 
       href="/admin/users/list">
       <i class="bi bi-people fs-5"></i> 
       <span>Manage Users</span>
    </a>

    {{!-- 5. System Settings --}}
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 {{#if (eq activeSection 'settings')}}active fw-bold{{/if}}" 
       href="/admin/system/settings">
       <i class="bi bi-gear fs-5"></i> 
       <span>System Settings</span>
    </a>

    
    {{!-- Logout --}}
    <form id="formAdminLogout" action="/account/logout" method="POST"></form>
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 text-danger fw-bold mt-2 border-top" 
       href="javascript: $('#formAdminLogout').submit()">
      <i class="bi bi-box-arrow-right fs-5"></i> 
      <span>Sign Out</span>
    </a>

  </div>
</div>